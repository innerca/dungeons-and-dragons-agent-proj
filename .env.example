# LLM API Keys - Copy this file to .env and fill in your keys
# NEVER commit .env to git

DEEPSEEK_API_KEY=your-deepseek-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database (defaults work for Docker Compose, override for local dev)
POSTGRES_PASSWORD=sao_dev_password
DATABASE_URL=postgresql://sao:sao_dev_password@localhost:5432/sao_game
REDIS_URL=redis://localhost:6379/0
